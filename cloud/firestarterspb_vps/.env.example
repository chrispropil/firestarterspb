TZ=America/Toronto

# Replace every placeholder before running on a VPS. Do not commit a real .env file.
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-long-random-postgres-password

N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=replace-with-admin-user
N8N_BASIC_AUTH_PASSWORD=replace-with-long-random-basic-auth-password
N8N_ENCRYPTION_KEY=replace-with-32-plus-character-random-key

DASHBOARD_PORT=8080
WORKER_PORT=8090

# Phase 1 defaults are safe. Set true only after reviewing the approved scripts.
FIRESTARTER_CLOUD_WORKER_EXECUTE=false
FIRESTARTER_CLOUD_LOG_DIR=/repo/logs/cloud
FIRESTARTER_CLOUD_STATE_DIR=/repo/state/cloud
