.env
*token*.json
data/research/binance_top100_excluding_existing_5_1month/
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Firestarter Live Audits generated / local-only outputs
reports/firestarter_live_audits/ai_match_index.csv
reports/firestarter_live_audits/review_packets/
reports/firestarter_live_audits/screenshots/
reports/firestarter_live_audits/screenshot_inbox/
reports/firestarter_live_audits/reviewed/
reports/firestarter_live_audits/pattern_searches/

# Keep docs, templates, summaries, and tiny samples commit-safe
!reports/firestarter_live_audits/README.md
!reports/firestarter_live_audits/README_AI_MATCH_INDEX.md
!reports/firestarter_live_audits/templates/
!reports/firestarter_live_audits/templates/*.md
!reports/firestarter_live_audits/samples/
!reports/firestarter_live_audits/samples/*.csv

# Generated research scripts (check/patch artifacts)
check_core88_*.py
patch_core88_*.py
scratch_validate.py

# Data bundles and research outputs
data/a4_bundle/
data/research/*/

# Report artifacts (non-Markdown)
reports/*.csv
reports/*.zip
reports/html/
reports/automation/
reports/profile_event_scanner/
reports/x2_patch_bundle/

# Python cache
scripts/__pycache__/
scripts/binance_spb/__pycache__/
scripts/visualization/__pycache__/

# Ad-hoc runner scripts
scripts/run_*.py
scripts/firestarter_a4_evidence_viewer.py
scripts/visualization/build_top100_x2_research_viewer.py
