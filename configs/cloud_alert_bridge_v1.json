{
  "status": "CLOUD_ALERT_BRIDGE_V1_MANUAL_ONLY",
  "description": "Cloud-safe notification bridge for FirestarterSPB research-control events. No secrets are stored in repo.",
  "ntfy": {
    "env_path": "/root/.config/firestarter/ntfy.env",
    "secrets_policy": "NTFY_TOPIC and NTFY_TOKEN must remain on the VPS only and must not be committed."
  },
  "notification": {
    "default_title": "FirestarterSPB",
    "default_priority": "4",
    "default_tags": "fire,chart_with_downwards_trend"
  },
  "paths": {
    "event_log": "state/cloud_alert_bridge/events.jsonl",
    "baseline_audit": "reports/cloud_data_pilot/v1/audit.json",
    "health_status": "state/cloud/health_status.json"
  },
  "baseline_policy": {
    "expected_rows_per_full_symbol": 8640,
    "accepted_zero_row_symbols": [
      "MATICUSDT"
    ],
    "accepted_zero_row_note": "Operator accepted MATICUSDT as a zero-row symbol for the first Phase 2A baseline. Any new zero-row or short symbol should emit HOLD."
  },
  "allowed_event_types": [
    "manual_test",
    "health",
    "baseline_audit"
  ],
  "future_alert_types_not_active_yet": [
    "fmlc_hanger",
    "flow_fade",
    "slingshot",
    "hollow_push",
    "domino_drop"
  ],
  "safety_flags": {
    "raw_data_mutation": false,
    "scoring_changes": false,
    "trading_execution": false,
    "exchange_credentials": false,
    "optimizer_production": false,
    "n8n_schedule_activation": false
  }
}
